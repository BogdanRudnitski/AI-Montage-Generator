# Copy this file to .env and set your machine's local IP.
# .env is gitignored – your URL and secrets are never committed.
#
# Backend: cd app/backend && source venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8000
# Then use that machine's IP below (same WiFi as your phone/simulator).

EXPO_PUBLIC_SERVER_URL=http://YOUR_IP:8000
